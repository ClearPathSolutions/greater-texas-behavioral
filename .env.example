# ---------------------------------------------------------------------------
# Contact / insurance-verification form email delivery (optional but recommended)
#
# The form works without these set (submissions are accepted and logged), but
# to actually receive lead emails, configure a Resend account (https://resend.com)
# and set the values below in Vercel → Project → Settings → Environment Variables.
# ---------------------------------------------------------------------------

# Your Resend API key
RESEND_API_KEY=

# Verified sender, e.g. "Greater Texas Behavioral <admissions@greatertexasbehavioral.com>"
CONTACT_FROM=

# Where inquiries are delivered (defaults to info@greatertexasbehavioral.com)
CONTACT_TO=info@greatertexasbehavioral.com
