# ---------------------------------------------------------------------------
# Clarion Labs — webchat + lead capture
#
# The insurance/contact form posts to /api/lead, which relays the lead into
# Clarion's public webchat flow. The cpx_ site key is PUBLIC and already shipped
# in the code (lib/site.ts), so this env var is OPTIONAL — set it only to
# override the key (e.g. after a rotation).
#
# IMPORTANT: In Clarion → Settings → Website Integrations, allowlist every
# production origin verbatim (apex + www + the .vercel.app alias + any custom
# domain). Non-allowlisted origins return 403; preview/branch URLs will 403.
# ---------------------------------------------------------------------------

# Optional override of the public Clarion site key
CLARION_SITE_KEY=

# Optional override of the Clarion API base (defaults to https://api.clarionlabs.ai)
CLARION_API=
